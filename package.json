    "express-rate-limit": "^7.5.1",
    "framer-motion": "^11.18.2",
    "got": "^14.6.6",
    "pm2": "^5.4.3",
    "psl": "^1.15.0",
    "puppeteer": "^22.15.0",
    "puppeteer-core": "^22.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^6.30.3",
    "react-simple-maps": "^3.0.0",
    "react-toastify": "^10.0.6",
    "recharts": "^2.15.4",
