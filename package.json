    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/svelte-fontawesome": "^0.2.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "astro": "^4.16.19",
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "chrome-aws-lambda": "^10.1.0",
    "chromium": "^3.0.3",
    "connect-history-api-fallback": "^2.0.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
