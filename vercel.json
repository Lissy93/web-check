{
  "version": 2,
  "buildCommand": "yarn build",
  "outputDirectory": "packages/site/dist",
  "rewrites": [
    { "source": "/check", "destination": "/check/index.html" },
    { "source": "/check/:path*", "destination": "/check/index.html" }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 20 }
  },
  "env": {
    "PLATFORM": "vercel",
    "CI": "false",
    "CHROME_PATH": "/usr/bin/chromium"
  },
  "build": {
    "env": { "PLATFORM": "vercel" }
  }
}
